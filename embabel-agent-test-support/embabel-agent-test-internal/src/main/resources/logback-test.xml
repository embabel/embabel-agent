<!--
  Logback test configuration for Embabel Agent library.

  This file is automatically picked up by Logback during tests (highest priority).
  It includes the library's default logging configuration (logback-embabel.xml).

  Tests can override logging levels via:
  - application.properties/yml in test resources
  - @SpringBootTest properties
  - System properties
-->
<configuration>
    <!-- Suppress verbose Logback status messages during tests -->
    <statusListener class="ch.qos.logback.core.status.NopStatusListener" />

    <include resource="logback-embabel.xml"/>
</configuration>
